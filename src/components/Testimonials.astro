---
// Testimonials — dati caricati dai file .md in src/data/testimonials/
import { readFileSync, readdirSync } from 'fs';
import { join } from 'path';

// Legge tutti i file .md dalla cartella testimonials
function parseMarkdownFrontmatter(content: string) {
  const match = content.match(/^---\n([\s\S]*?)\n---/);
  if (!match) return null;
  const data: Record<string, string> = {};
  match[1].split('\n').forEach(line => {
    const idx = line.indexOf(':');
    if (idx > -1) {
      const key = line.slice(0, idx).trim();
      const val = line.slice(idx + 1).trim();
      data[key] = val;
    }
  });
  return data;
}

const dir = join(process.cwd(), 'src/data/testimonials');
const testimonials = readdirSync(dir)
  .filter(f => f.endsWith('.md'))
  .map(file => {
    const content = readFileSync(join(dir, file), 'utf-8');
    return parseMarkdownFrontmatter(content);
  })
  .filter(Boolean);

const avatars = ['👨‍💼', '👩‍💼', '👨‍🎓'];
---

<section class="py-20" style="background: var(--color-bg-secondary);">
  <div class="max-w-7xl mx-auto px-6">
    <!-- Section Header -->
    <div class="mb-16 text-center">
      <h2 class="text-4xl md:text-5xl font-bold mb-4">Testimonianze</h2>
      <p class="text-lg max-w-2xl mx-auto" style="color: var(--color-text-secondary);">
        Cosa dicono di me i miei colleghi e clienti.
      </p>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {testimonials.map((t, i) => (
        <div class="card">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-12 h-12 rounded-full flex items-center justify-center text-xl"
                 style="background: rgba(0,113,227,0.15);">
              {avatars[i % avatars.length]}
            </div>
            <div>
              <p class="font-bold">{t!.name}</p>
              <p class="text-sm" style="color: var(--color-text-secondary);">{t!.role}</p>
            </div>
          </div>
          <!-- Star rating -->
          <div class="flex gap-1 mb-3" aria-label="5 stelle su 5">
            {Array(5).fill(0).map(() => (
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"
                   style="color: var(--color-accent);">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
            ))}
          </div>
          <p class="italic" style="color: var(--color-text-secondary);">"{t!.quote}"</p>
        </div>
      ))}
    </div>
  </div>
</section>
