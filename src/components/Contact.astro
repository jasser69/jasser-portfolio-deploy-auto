---
// Contact Section — form con FormSpree (sostituisci YOUR_FORM_ID con il tuo ID da formspree.io)
import settings from '../data/settings.json';
const FORMSPREE_ID = 'YOUR_FORM_ID'; // <-- Registrati su formspree.io e sostituisci questo valore
---

<section id="contact" class="py-20" style="background: var(--color-bg);">
  <div class="max-w-4xl mx-auto px-6">

    <div class="mb-16 text-center">
      <h2 class="text-4xl md:text-5xl font-bold mb-4">Contattami</h2>
      <p class="text-lg" style="color: var(--color-text-secondary);">
        Hai un progetto in mente? Parliamone!
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
      <!-- Contact Info -->
      <div class="space-y-8">
        <div>
          <h3 class="text-lg font-bold mb-2">Email</h3>
          <a href={`mailto:${settings.email}`} style="color: var(--color-accent);">
            {settings.email}
          </a>
        </div>

        <div>
          <h3 class="text-lg font-bold mb-2">Social</h3>
          <div class="flex gap-4">
            <a href={settings.github} target="_blank" rel="noopener noreferrer"
               style="color: var(--color-accent);">GitHub</a>
            <a href={settings.instagram} target="_blank" rel="noopener noreferrer"
               style="color: var(--color-accent);">Instagram</a>
            <a href={settings.linkedin} target="_blank" rel="noopener noreferrer"
               style="color: var(--color-accent);">LinkedIn</a>
          </div>
        </div>

        <div>
          <h3 class="text-lg font-bold mb-2">Disponibilità</h3>
          <p style="color: var(--color-text-secondary);">
            Disponibile per progetti, collaborazioni e opportunità di lavoro.
          </p>
        </div>

        <div>
          <h3 class="text-lg font-bold mb-2">Lingue</h3>
          <p style="color: var(--color-text-secondary);">
            Italiano, Arabo, Francese, Inglese
          </p>
        </div>

        <!-- Response time badge -->
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-medium"
             style="background: rgba(0,113,227,0.1); color: var(--color-accent);">
          <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
          Risposta entro 24 ore
        </div>
      </div>

      <!-- Contact Form -->
      <form id="contact-form" class="space-y-6">
        <div>
          <label for="name" class="block text-sm font-medium mb-2">Nome</label>
          <input
            type="text"
            id="name"
            name="name"
            required
            autocomplete="name"
            class="w-full px-4 py-3 rounded-lg text-sm transition-shadow"
            style="border: 1px solid var(--color-border); background: var(--color-bg); color: var(--color-text); outline: none;"
            placeholder="Il tuo nome"
          />
        </div>

        <div>
          <label for="email" class="block text-sm font-medium mb-2">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            autocomplete="email"
            class="w-full px-4 py-3 rounded-lg text-sm transition-shadow"
            style="border: 1px solid var(--color-border); background: var(--color-bg); color: var(--color-text); outline: none;"
            placeholder="tua@email.com"
          />
        </div>

        <div>
          <label for="subject" class="block text-sm font-medium mb-2">Oggetto</label>
          <input
            type="text"
            id="subject"
            name="subject"
            required
            class="w-full px-4 py-3 rounded-lg text-sm transition-shadow"
            style="border: 1px solid var(--color-border); background: var(--color-bg); color: var(--color-text); outline: none;"
            placeholder="Di cosa vuoi parlarmi?"
          />
        </div>

        <div>
          <label for="message" class="block text-sm font-medium mb-2">Messaggio</label>
          <textarea
            id="message"
            name="message"
            required
            rows="5"
            class="w-full px-4 py-3 rounded-lg text-sm resize-none transition-shadow"
            style="border: 1px solid var(--color-border); background: var(--color-bg); color: var(--color-text); outline: none;"
            placeholder="Il tuo messaggio..."
          ></textarea>
        </div>

        <!-- Honeypot anti-spam -->
        <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />

        <div id="form-error" class="hidden text-sm px-4 py-3 rounded-lg"
             style="background: rgba(239,68,68,0.1); color: #ef4444; border: 1px solid rgba(239,68,68,0.2);">
        </div>
        <div id="form-success" class="hidden text-sm px-4 py-3 rounded-lg"
             style="background: rgba(34,197,94,0.1); color: #16a34a; border: 1px solid rgba(34,197,94,0.2);">
          ✓ Messaggio inviato con successo! Ti risponderò entro 24 ore.
        </div>

        <button
          id="submit-btn"
          type="submit"
          class="w-full px-8 py-4 rounded-lg font-medium text-white transition-all duration-300 hover:scale-105 hover:shadow-lg disabled:opacity-60 disabled:cursor-not-allowed disabled:hover:scale-100"
          style="background: var(--color-accent);"
        >
          Invia Messaggio
        </button>

        <p class="text-xs text-center" style="color: var(--color-text-secondary);">
          Il tuo messaggio è al sicuro. Non condivido mai i dati con terze parti.
        </p>
      </form>
    </div>
  </div>
</section>

<script define:vars={{ FORMSPREE_ID }}>
  const nameEl    = document.getElementById('name');
  const emailEl   = document.getElementById('email');
  const subjectEl = document.getElementById('subject');
  const messageEl = document.getElementById('message');
  const submitBtn = document.getElementById('submit-btn');
  const errorEl   = document.getElementById('form-error');
  const successEl = document.getElementById('form-success');

  // Focus ring via JS to avoid Tailwind purge issues
  [nameEl, emailEl, subjectEl, messageEl].forEach(el => {
    el?.addEventListener('focus', () => {
      (el as HTMLElement).style.boxShadow = '0 0 0 2px var(--color-accent)';
    });
    el?.addEventListener('blur', () => {
      (el as HTMLElement).style.boxShadow = '';
    });
  });

  const contactForm = document.getElementById('contact-form');

  contactForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    if (errorEl)   errorEl.classList.add('hidden');
    if (successEl) successEl.classList.add('hidden');

    const name    = (nameEl as HTMLInputElement)?.value.trim() ?? '';
    const email   = (emailEl as HTMLInputElement)?.value.trim() ?? '';
    const subject = (subjectEl as HTMLInputElement)?.value.trim() ?? '';
    const message = (messageEl as HTMLTextAreaElement)?.value.trim() ?? '';

    // Disable button
    if (submitBtn) {
      (submitBtn as HTMLButtonElement).disabled = true;
      submitBtn.textContent = 'Invio in corso...';
    }

    try {
      const isConfigured = FORMSPREE_ID !== 'YOUR_FORM_ID' && FORMSPREE_ID !== '';
      
      if (isConfigured) {
        const res = await fetch(`https://formspree.io/f/${FORMSPREE_ID}`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({ name, email, subject, message }),
        });
        if (!res.ok) throw new Error('Errore invio');
        if (successEl) successEl.classList.remove('hidden');
      } else {
        const mailtoLink = `mailto:jasserhassine749@gmail.com?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(`Nome: ${name}\nEmail: ${email}\n\n${message}`)}`;
        window.location.href = mailtoLink;
        if (successEl) {
          successEl.textContent = '✓ Client email aperto! Invia la mail per completare il contatto.';
          successEl.classList.remove('hidden');
        }
      }

      (nameEl as HTMLInputElement).value    = '';
      (emailEl as HTMLInputElement).value   = '';
      (subjectEl as HTMLInputElement).value = '';
      (messageEl as HTMLTextAreaElement).value = '';
    } catch {
      if (errorEl) {
        errorEl.textContent = 'Errore durante l\'invio. Riprova o scrivi direttamente a jasserhassine749@gmail.com';
        errorEl.classList.remove('hidden');
      }
    } finally {
      if (submitBtn) {
        (submitBtn as HTMLButtonElement).disabled = false;
        submitBtn.textContent = 'Invia Messaggio';
      }
    }
  });
</script>
