---
import Layout from '../../layouts/Layout.astro';
import { readFileSync, readdirSync } from 'fs';
import { join } from 'path';

export async function getStaticPaths() {
  const dir = join(process.cwd(), 'src/data/blog');
  const files = readdirSync(dir).filter(f => f.endsWith('.md'));
  
  return files.map(file => ({
    params: { slug: file.replace('.md', '') },
  }));
}

const { slug } = Astro.params;
const filePath = join(process.cwd(), 'src/data/blog', `${slug}.md`);
const content = readFileSync(filePath, 'utf-8');

function parseMarkdown(content: string) {
  const match = content.match(/^---\n([\s\S]*?)\n---([\s\S]*)$/);
  if (!match) return { data: {}, body: content };
  
  const rawData = match[1];
  const body = match[2];
  const data: Record<string, string> = {};
  
  rawData.split('\n').forEach(line => {
    const idx = line.indexOf(':');
    if (idx > -1) {
      data[line.slice(0, idx).trim()] = line.slice(idx + 1).trim();
    }
  });
  
  return { data, body };
}

const { data, body } = parseMarkdown(content);

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('it-IT', {
    day: 'numeric', month: 'long', year: 'numeric'
  });
}
---

<Layout title={`${data.title} - Blog`}>
  <main class="pt-32 pb-20">
    <article class="max-w-3xl mx-auto px-6">
      <div class="mb-8">
        <a href="/blog" class="text-sm font-medium mb-4 inline-block" style="color: var(--color-accent);">
          ← Torna al blog
        </a>
        <div class="flex items-center gap-2 text-xs font-medium mb-4" style="color: var(--color-accent);">
          <span class="px-3 py-1 rounded-full" style="background: rgba(0,113,227,0.1);">
            {data.category}
          </span>
          <span style="color: var(--color-text-secondary);">•</span>
          <span style="color: var(--color-text-secondary);">{data.readTime} min lettura</span>
        </div>
        <h1 class="text-4xl md:text-5xl font-bold mb-4">{data.title}</h1>
        <p class="text-sm" style="color: var(--color-text-secondary);">
          Pubblicato il {formatDate(data.date)}
        </p>
      </div>

      {data.image && (
        <div class="mb-12 rounded-2xl overflow-hidden aspect-video bg-gray-100 dark:bg-gray-800">
          <img src={data.image} alt={data.title} class="w-full h-full object-cover" />
        </div>
      )}

      <div class="prose prose-lg dark:prose-invert max-w-none" style="color: var(--color-text);">
        {body.split('\n').map(line => {
          if (line.startsWith('# ')) return <h1 class="text-3xl font-bold mt-8 mb-4">{line.replace('# ', '')}</h1>;
          if (line.startsWith('## ')) return <h2 class="text-2xl font-bold mt-8 mb-4">{line.replace('## ', '')}</h2>;
          if (line.startsWith('### ')) return <h3 class="text-xl font-bold mt-6 mb-3">{line.replace('### ', '')}</h3>;
          if (line.trim() === '') return <br />;
          return <p class="mb-4 leading-relaxed">{line}</p>;
        })}
      </div>

      <div class="mt-16 pt-8 border-t" style="border-color: var(--color-border);">
        <h3 class="text-xl font-bold mb-4">Ti è piaciuto l'articolo?</h3>
        <p class="mb-6" style="color: var(--color-text-secondary);">
          Condividilo o contattami se hai domande su questo argomento.
        </p>
        <a href="/#contact" class="inline-block px-6 py-3 rounded-lg text-white font-medium" style="background: var(--color-accent);">
          Contattami
        </a>
      </div>
    </article>
  </main>
</Layout>
